# ─── Backend — Production ──────────────────────────────
# Template. Los valores ${VAR} los injecta docker-compose.
# Copiar como .env.production y ajustar si se ejecuta fuera de Docker.
# ─────────────────────────────────────────────────────

NODE_ENV=production
PORT=8080

# Database (valores injectados por docker-compose)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@app-postgres:5432/${POSTGRES_DB}

# CORS (dominio o IP pública de la app)
CORS_ORIGIN=${CORS_ORIGIN}

# Logging
LOG_LEVEL=info

# OpenTelemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=app-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
