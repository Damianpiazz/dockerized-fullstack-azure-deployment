# ─── Backend — Development ─────────────────────────────
NODE_ENV=development
PORT=8080

# Database
DATABASE_URL=postgresql://app_user:app_pass@localhost:5432/app_db

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=app-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
