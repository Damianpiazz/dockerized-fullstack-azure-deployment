# ─── Backend — Test ────────────────────────────────────
NODE_ENV=test
PORT=0

# Database (PostgreSQL test en puerto 5433)
DATABASE_URL=postgresql://app_user:app_pass@localhost:5433/app_db_test

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging (silent en tests)
LOG_LEVEL=silent

# OpenTelemetry (deshabilitado en tests)
OTEL_ENABLED=false
