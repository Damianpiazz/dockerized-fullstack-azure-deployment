# ─── Simulacion Local del Despliegue Azure ─────────
# Copiar como .env.simulate y ajustar si es necesario.
# docker compose -f docker-compose.simulate.yml --env-file .env.simulate up
# ─────────────────────────────────────────────────────

# Base de datos
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_pass

# Backend
BACKEND_PORT=8080
CORS_ORIGIN=http://localhost

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost/api

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
PROMETHEUS_RETENTION=15d

# Nginx
NGINX_PORT=80
