# ─────────────────────────────────────────────
# terraform.tfvars — Configuración de producción
# Copiá este archivo como terraform.tfvars
# NUNCA subas este archivo al repositorio
# ─────────────────────────────────────────────

prefix   = "app"
location = "East US"
vm_size  = "Standard_B2s"

admin_username = "azureuser"
ssh_public_key = "ssh-rsa AAAA... tu_clave_publica_aqui"
ssh_source_ip  = "190.210.x.x/32"

# Dominio opcional (dejar vacío si no tenés)
domain_name = ""
# domain_name = "miapp.com"

# Azure Application Insights (deshabilitado por defecto — usar Prometheus/Grafana)
# enable_application_insights = true
