# /opt/app/.env
# Este archivo se crea MANUALMENTE en la VM, no se sube al repo

# Base de datos
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=una_password_muy_segura_aqui

# Docker Registry (GitHub Container Registry)
DOCKER_REGISTRY=ghcr.io/TU_USUARIO_GITHUB

# Tag de imagen (el CI/CD lo setea dinamicamente)
IMAGE_TAG=latest

# CORS: La URL publica de tu app
# Si tenes dominio: https://miapp.com
# Si no: http://IP_DE_TU_VM
CORS_ORIGIN=http://IP_DE_TU_VM

# URL del API que ve el navegador del usuario
# Si tenes dominio: https://miapp.com/api
# Si no: http://IP_DE_TU_VM/api
NEXT_PUBLIC_API_URL=http://IP_DE_TU_VM/api
