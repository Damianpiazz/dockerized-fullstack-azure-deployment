# ─── Desarrollo Local ──────────────────────────────
# Las variables tienen defaults en docker-compose.dev.yml,
# pero podes overridearlas desde este archivo.
# Copiar como .env (o exportar en el shell) y ajustar.
# ─────────────────────────────────────────────────────

# Base de datos
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_pass
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8080

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# CORS
CORS_ORIGIN=http://localhost:3000
